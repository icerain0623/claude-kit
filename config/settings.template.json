      "Bash(clang *)",
      "Bash(clang++ *)",
      "Bash(go *)",
      "Bash(cargo *)",
      "Bash(java *)",
      "Bash(javac *)",
      "Bash(gradle *)",
      "Bash(./gradlew *)",
      "Bash(mvn *)",
      "Bash(python3 *)",
      "Bash(pip3 *)",
      "Bash(pip *)",
      "Bash(sqlite3 *)",
      "Bash(npx vitest *)",
      "Bash(npx vitest)",
      "Bash(npx tsc *)",
      "Bash(npx tsc)",
      "Bash(npx eslint *)",
