      "Bash(grep:*)",
      "Bash(git add:*)",
      "Bash(git mv:*)",
      "Bash(git stash:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
