  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/block-denied-commands.sh",
            "timeout": 5,
            "statusMessage": "Security check..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/warn-dangerous.sh",
            "timeout": 5,
            "statusMessage": "Checking for dangerous commands..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/block-dev-servers.sh",
            "timeout": 5,
            "statusMessage": "Checking for dev-server launch..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/git-workflow.sh",
            "timeout": 5,
            "statusMessage": "Checking git workflow rules..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/check-package-safety.sh",
            "timeout": 30,
            "statusMessage": "Checking package safety via Socket.dev..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/warn-secrets.sh",
            "timeout": 5,
            "statusMessage": "Checking for secrets..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh",
    "padding": 2
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "figma@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "deploy-on-aws@agent-plugins-for-aws": true,
    "swift-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "agent-plugins-for-aws": {
      "source": {
        "source": "github",
        "repo": "awslabs/agent-plugins"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "registry.npmjs.org",
        "api.npmjs.org",
        "crates.io",
        "static.crates.io",
        "index.crates.io",
        "pypi.org",
        "files.pythonhosted.org",
        "proxy.golang.org",
        "sum.golang.org",
        "storage.googleapis.com",
        "rubygems.org",
        "repo1.maven.org",
        "plugins.gradle.org",
        "cocoapods.org",
        "cdn.cocoapods.org",
        "pub.dev",
        "github.com",
        "api.github.com",
        "socket.dev",
        "api.socket.dev"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/Documents/GitHub",
        "~/Documents/claude-shared",
        "~/Developers",
        "~/.gitignore_global",
        "~/.gitconfig",
        "~/.claude/skills",
        "~/.cargo",
        "~/.rustup",
        "~/.npm",
        "~/.cache",
        "~/.local/share/pip",
        "~/.pyenv",
        "~/.nvm",
        "~/.bun",
        "~/.gradle",
        "~/.m2"
      ],
      "allowRead": [
        "/etc/gitconfig",
        "/etc/gitattributes",
        "/etc/ssl"
      ]
    },
    "excludedCommands": [
      "docker",
      "kubectl",
      "git",
      "cargo",
      "rustup",
      "gh",
      "pbcopy",
      "pbpaste",
      "colima",
      "go"
    ]
  },
  "effortLevel": "xhigh",
  "skipWorkflowUsageWarning": true,
  "skipAutoPermissionPrompt": true
}
